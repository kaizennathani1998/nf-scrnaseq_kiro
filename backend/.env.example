# AWS credentials (or use IAM role / AWS profile)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Required for temporary credentials (ASIA* keys from SSO/assumed role)
AWS_SESSION_TOKEN=

# S3 bucket for FASTQ uploads and pipeline outputs
S3_BUCKET=my-scrnaseq-bucket
S3_PREFIX=scrnaseq

# AWS HealthOmics
# Register nf-core/scrnaseq as a Ready2Run or private workflow first
HEALTHOMICS_WORKFLOW_ID=
HEALTHOMICS_ROLE_ARN=arn:aws:iam::123456789:role/HealthOmicsRole
HEALTHOMICS_OUTPUT_URI=s3://my-scrnaseq-bucket/outputs/

# Amazon Bedrock (Claude)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_REGION=us-east-1

# Local data directory for run metadata
DATA_DIR=./data
